{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product in inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "costPrice": { "type": "number" },
        "stock": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "qrCodeUrl": { "type": "string" },
        "imageUrl": { "type": "string" },
        "variants": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "tax": { "type": "number" },
        "discount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "customerPhone": { "type": "string" },
        "staffId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "total", "paymentMethod"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer database",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "loyaltyPoints": { "type": "number" },
        "pendingPayment": { "type": "number" }
      },
      "required": ["phone"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expenses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "staffId": { "type": "string" }
      },
      "required": ["description", "amount", "date"]
    },
    "Note": {
      "title": "Note",
      "description": "User notes and ideas",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product inventory"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer records"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Business expenses"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Personalized business notes"
    }
  }
}
